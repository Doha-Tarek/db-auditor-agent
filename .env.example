@"
# ── LLM ───────────────────────────────────
GROK_API_KEY=your_groq_api_key_here
GROK_MODEL=llama-3.3-70b-versatile
GROK_MAX_TOKENS=1000

# ── Target Database ────────────────────────
SQLSERVER_URL=mssql+pyodbc://localhost/target_db?driver=ODBC+Driver+17+for+SQL+Server&Trusted_Connection=yes

# ── Audit Database ─────────────────────────
AUDIT_DB_URL=mssql+pyodbc://localhost/audit_db?driver=ODBC+Driver+17+for+SQL+Server&Trusted_Connection=yes

# ── Reports ────────────────────────────────
REPORTS_OUTPUT_PATH=reports/output

# ── Scheduler ─────────────────────────────
SCAN_SCHEDULE_HOURS=6
MAX_ROWS_FULL_SCAN=500000
SAMPLE_SIZE=10000
"@ | Out-File -FilePath ".env.example" -Encoding utf8